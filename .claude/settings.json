{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 -m venv:*)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(python -m pip install:*)",
      "Bash(pip install:*)",
      "Bash(uvicorn:*)",
      "Bash(python -m uvicorn:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm create:*)",
      "Bash(npx:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Read(./**/.env*)",
      "Read(./**/secrets/**)"
    ]
  }
}
